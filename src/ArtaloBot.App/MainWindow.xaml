<Window x:Class="ArtaloBot.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:viewModels="clr-namespace:ArtaloBot.App.ViewModels"
        xmlns:views="clr-namespace:ArtaloBot.App.Views"
        mc:Ignorable="d"
        Title="ArtaloBot"
        Height="750" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="Segoe UI Variable, Segoe UI">

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:ChatViewModel}">
            <views:ChatView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:MCPViewModel}">
            <views:MCPView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ChannelsViewModel}">
            <views:ChannelsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:AgentsViewModel}">
            <views:AgentsView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar -->
        <Border Grid.Column="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- App Header -->
                <StackPanel Grid.Row="0" Margin="16,20,16,16">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" CornerRadius="8" Background="{StaticResource AccentBrush}" Margin="0,0,12,0">
                            <materialDesign:PackIcon Kind="Robot" Width="24" Height="24"
                                                     Foreground="White"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="ArtaloBot"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="AI Assistant"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- New Chat Button -->
                <Button Grid.Row="1"
                        Style="{StaticResource Win11PrimaryButton}"
                        Command="{Binding NewChatCommand}"
                        Margin="16,0,16,16"
                        Height="40">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="New Chat" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Navigation -->
                <StackPanel Grid.Row="2" Margin="8,0">
                    <Button Style="{StaticResource Win11NavButton}"
                            Command="{Binding NavigateToChatCommand}"
                            Margin="0,2">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Chat" Width="20" Height="20"
                                                     Foreground="{StaticResource AccentBrush}"
                                                     Margin="0,0,12,0" VerticalAlignment="Center" />
                            <TextBlock Text="Chat" FontSize="14" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource Win11NavButton}"
                            Command="{Binding NavigateToSettingsCommand}"
                            Margin="0,2">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cog" Width="20" Height="20"
                                                     Foreground="{StaticResource TextSecondaryBrush}"
                                                     Margin="0,0,12,0" VerticalAlignment="Center" />
                            <TextBlock Text="Settings" FontSize="14" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource Win11NavButton}"
                            Command="{Binding NavigateToMCPCommand}"
                            Margin="0,2">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Puzzle" Width="20" Height="20"
                                                     Foreground="{StaticResource TextSecondaryBrush}"
                                                     Margin="0,0,12,0" VerticalAlignment="Center" />
                            <TextBlock Text="Skills" FontSize="14" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource Win11NavButton}"
                            Command="{Binding NavigateToChannelsCommand}"
                            Margin="0,2">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Forum" Width="20" Height="20"
                                                     Foreground="{StaticResource TextSecondaryBrush}"
                                                     Margin="0,0,12,0" VerticalAlignment="Center" />
                            <TextBlock Text="Channels" FontSize="14" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource Win11NavButton}"
                            Command="{Binding NavigateToAgentsCommand}"
                            Margin="0,2">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountMultiple" Width="20" Height="20"
                                                     Foreground="{StaticResource TextSecondaryBrush}"
                                                     Margin="0,0,12,0" VerticalAlignment="Center" />
                            <TextBlock Text="Agents" FontSize="14" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Recent Chats Section -->
                    <TextBlock Text="Recent"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="12,24,12,8" />

                    <ListBox ItemsSource="{Binding SessionsViewModel.Sessions}"
                             SelectedItem="{Binding SessionsViewModel.SelectedSession}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             MaxHeight="300">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="12,10" />
                                <Setter Property="Margin" Value="0,1" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="border"
                                                    Background="Transparent"
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" TargetName="border" Value="#E8E8E8" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" TargetName="border" Value="{StaticResource AccentLightBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Title}"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding TimeAgo}"
                                               FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="8,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

                <!-- Bottom Actions -->
                <StackPanel Grid.Row="3" Margin="8,16">
                    <Button Style="{StaticResource Win11NavButton}"
                            Command="{Binding OpenDebugWindowCommand}"
                            Margin="0,2">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Bug" Width="20" Height="20"
                                                     Foreground="{StaticResource TextSecondaryBrush}"
                                                     Margin="0,0,12,0" VerticalAlignment="Center" />
                            <TextBlock Text="Debug Console" FontSize="14" VerticalAlignment="Center" />
                            <Border Background="#107C10"
                                    CornerRadius="8"
                                    Padding="6,2"
                                    Margin="8,0,0,0"
                                    Visibility="{Binding IsDebugWindowOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="OPEN" FontSize="9" FontWeight="Bold" Foreground="White" />
                            </Border>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource Win11NavButton}"
                            Command="{Binding ToggleThemeCommand}"
                            Margin="0,2">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Brightness6" Width="20" Height="20"
                                                     Foreground="{StaticResource TextSecondaryBrush}"
                                                     Margin="0,0,12,0" VerticalAlignment="Center" />
                            <TextBlock Text="Toggle Theme" FontSize="14" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentView}" />
    </Grid>
</Window>
