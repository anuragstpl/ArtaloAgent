<Window x:Class="ArtaloBot.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:viewModels="clr-namespace:ArtaloBot.App.ViewModels"
        xmlns:views="clr-namespace:ArtaloBot.App.Views"
        xmlns:converters="clr-namespace:ArtaloBot.App.Converters"
        mc:Ignorable="d"
        Title="ArtaloBot"
        Icon="Assets/app.ico"
        Height="750" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="Segoe UI Variable, Segoe UI">

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:ChatViewModel}">
            <views:ChatView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:MCPViewModel}">
            <views:MCPView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ChannelsViewModel}">
            <views:ChannelsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:AgentsViewModel}">
            <views:AgentsView />
        </DataTemplate>

        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar - Clean White -->
        <Border Grid.Column="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- App Header -->
                <StackPanel Grid.Row="0" Margin="20,24,20,20">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="48" Height="48" CornerRadius="12" Margin="0,0,12,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.25" Color="#764ba2"/>
                            </Border.Effect>
                            <Image Source="Assets/logo.png" Width="48" Height="48" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="ArtaloBot"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="AI Assistant"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- New Chat Button -->
                <Button Grid.Row="1"
                        Style="{StaticResource Win11PrimaryButton}"
                        Command="{Binding NewChatCommand}"
                        Margin="16,0,16,20"
                        Height="42">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="New Chat" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Navigation Menu -->
                <StackPanel Grid.Row="2" Margin="8,0">
                    <!-- Chat -->
                    <Border x:Name="ChatNavItem" CornerRadius="8" Margin="0,2" Cursor="Hand"
                            MouseLeftButtonDown="OnChatTileClick">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="12,10"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedNavIndex}" Value="0">
                                        <Setter Property="Background" Value="{StaticResource AccentLightBrush}"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Selection Indicator -->
                            <Border Width="3" Height="20" CornerRadius="2" Margin="-12,0,12,0" HorizontalAlignment="Left">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="0">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <materialDesign:PackIcon Grid.Column="0" Kind="Chat" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center">
                                <materialDesign:PackIcon.Style>
                                    <Style TargetType="materialDesign:PackIcon">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="0">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </materialDesign:PackIcon.Style>
                            </materialDesign:PackIcon>
                            <TextBlock Grid.Column="1" Text="Chat" FontSize="14" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="0">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Settings -->
                    <Border CornerRadius="8" Margin="0,2" Cursor="Hand"
                            MouseLeftButtonDown="OnSettingsTileClick">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="12,10"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedNavIndex}" Value="1">
                                        <Setter Property="Background" Value="{StaticResource AccentLightBrush}"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="3" Height="20" CornerRadius="2" Margin="-12,0,12,0" HorizontalAlignment="Left">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="1">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <materialDesign:PackIcon Grid.Column="0" Kind="Cog" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center">
                                <materialDesign:PackIcon.Style>
                                    <Style TargetType="materialDesign:PackIcon">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="1">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </materialDesign:PackIcon.Style>
                            </materialDesign:PackIcon>
                            <TextBlock Grid.Column="1" Text="Settings" FontSize="14" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="1">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Skills -->
                    <Border CornerRadius="8" Margin="0,2" Cursor="Hand"
                            MouseLeftButtonDown="OnSkillsTileClick">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="12,10"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedNavIndex}" Value="2">
                                        <Setter Property="Background" Value="{StaticResource AccentLightBrush}"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="3" Height="20" CornerRadius="2" Margin="-12,0,12,0" HorizontalAlignment="Left">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="2">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <materialDesign:PackIcon Grid.Column="0" Kind="Puzzle" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center">
                                <materialDesign:PackIcon.Style>
                                    <Style TargetType="materialDesign:PackIcon">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="2">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </materialDesign:PackIcon.Style>
                            </materialDesign:PackIcon>
                            <TextBlock Grid.Column="1" Text="Skills" FontSize="14" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="2">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Channels -->
                    <Border CornerRadius="8" Margin="0,2" Cursor="Hand"
                            MouseLeftButtonDown="OnChannelsTileClick">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="12,10"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedNavIndex}" Value="3">
                                        <Setter Property="Background" Value="{StaticResource AccentLightBrush}"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="3" Height="20" CornerRadius="2" Margin="-12,0,12,0" HorizontalAlignment="Left">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="3">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <materialDesign:PackIcon Grid.Column="0" Kind="Forum" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center">
                                <materialDesign:PackIcon.Style>
                                    <Style TargetType="materialDesign:PackIcon">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="3">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </materialDesign:PackIcon.Style>
                            </materialDesign:PackIcon>
                            <TextBlock Grid.Column="1" Text="Channels" FontSize="14" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="3">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Agents -->
                    <Border CornerRadius="8" Margin="0,2" Cursor="Hand"
                            MouseLeftButtonDown="OnAgentsTileClick">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="12,10"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedNavIndex}" Value="4">
                                        <Setter Property="Background" Value="{StaticResource AccentLightBrush}"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="3" Height="20" CornerRadius="2" Margin="-12,0,12,0" HorizontalAlignment="Left">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="4">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <materialDesign:PackIcon Grid.Column="0" Kind="AccountMultiple" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center">
                                <materialDesign:PackIcon.Style>
                                    <Style TargetType="materialDesign:PackIcon">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="4">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </materialDesign:PackIcon.Style>
                            </materialDesign:PackIcon>
                            <TextBlock Grid.Column="1" Text="Agents" FontSize="14" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="4">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Recent Chats Section -->
                <StackPanel Grid.Row="3" Margin="8,24,8,0">
                    <TextBlock Text="Recent"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="12,0,12,8" />

                    <ListBox ItemsSource="{Binding SessionsViewModel.Sessions}"
                             SelectedItem="{Binding SessionsViewModel.SelectedSession}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             MaxHeight="280">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="12,10" />
                                <Setter Property="Margin" Value="0,1" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="border"
                                                    Background="Transparent"
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" TargetName="border" Value="{StaticResource SurfaceLightBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" TargetName="border" Value="{StaticResource AccentLightBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Title}"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding TimeAgo}"
                                               FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="8,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

                <!-- Bottom Actions -->
                <StackPanel Grid.Row="4" Margin="8,16">
                    <Border CornerRadius="6" Margin="0,2" Cursor="Hand"
                            Background="Transparent"
                            MouseLeftButtonDown="OnDebugTileClick">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid Margin="12,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Kind="Bug" Width="20" Height="20"
                                                     Foreground="{StaticResource TextSecondaryBrush}"
                                                     Margin="0,0,12,0" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Debug Console" FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" />
                            <Border Grid.Column="2" Background="#10B981" CornerRadius="4" Padding="6,2"
                                    Visibility="{Binding IsDebugWindowOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="OPEN" FontSize="9" FontWeight="Bold" Foreground="White" />
                            </Border>
                        </Grid>
                    </Border>

                    <Border CornerRadius="6" Margin="0,2" Cursor="Hand"
                            Background="Transparent"
                            MouseLeftButtonDown="OnThemeTileClick">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal" Margin="12,10">
                            <materialDesign:PackIcon Kind="Brightness6" Width="20" Height="20"
                                                     Foreground="{StaticResource TextSecondaryBrush}"
                                                     Margin="0,0,12,0" VerticalAlignment="Center" />
                            <TextBlock Text="Toggle Theme" FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentView}" />
    </Grid>
</Window>
