<UserControl x:Class="ArtaloBot.App.Views.AgentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:ArtaloBot.App.Converters"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolConverter x:Key="InverseBooleanConverter" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Agents List -->
        <Border Grid.Column="0"
                Background="{DynamicResource MaterialDesignCardBackground}"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="16,16,16,8">
                    <TextBlock Text="Custom Agents"
                               Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                               FontWeight="Medium" />
                    <TextBlock Text="Create AI agents with custom knowledge"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Opacity="0.7"
                               Margin="0,4,0,0" />
                </StackPanel>

                <!-- New Agent Button -->
                <Button Grid.Row="1"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding NewAgentCommand}"
                        Margin="16,8,16,16"
                        Height="40">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="New Agent" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Agents List -->
                <ListBox Grid.Row="2"
                         ItemsSource="{Binding Agents}"
                         SelectedItem="{Binding SelectedAgent}"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="8,0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
                            <Setter Property="Padding" Value="12" />
                            <Setter Property="Margin" Value="0,2" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="40" Height="40"
                                        CornerRadius="8"
                                        Background="{DynamicResource PrimaryHueLightBrush}"
                                        Margin="0,0,12,0">
                                    <materialDesign:PackIcon Kind="{Binding Icon}"
                                                             Width="24" Height="24"
                                                             Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center" />
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="Medium"
                                                   FontSize="14" />
                                        <materialDesign:Chip Content="Default"
                                                             Margin="8,0,0,0"
                                                             Visibility="{Binding IsDefault, Converter={StaticResource BoolToVis}}"
                                                             Background="{DynamicResource SecondaryHueMidBrush}"
                                                             Foreground="White"
                                                             FontSize="10"
                                                             Height="20" />
                                    </StackPanel>
                                    <TextBlock Opacity="0.7" FontSize="12" Margin="0,2,0,0">
                                        <Run Text="{Binding TotalDocuments, Mode=OneWay}" />
                                        <Run Text="docs," />
                                        <Run Text="{Binding TotalChunks, Mode=OneWay}" />
                                        <Run Text="chunks" />
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="8" Height="8"
                                             Fill="{DynamicResource PrimaryHueMidBrush}"
                                             Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Status -->
                <TextBlock Grid.Row="3"
                           Text="{Binding StatusMessage}"
                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                           Margin="16,8"
                           Opacity="0.7" />
            </Grid>
        </Border>

        <!-- Right Panel: Agent Details / Editor -->
        <Grid Grid.Column="1">
            <!-- No Selection State -->
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="{Binding SelectedAgent, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <materialDesign:PackIcon Kind="AccountCircle"
                                         Width="64" Height="64"
                                         HorizontalAlignment="Center"
                                         Opacity="0.3" />
                <TextBlock Text="Select an agent or create a new one"
                           Style="{StaticResource MaterialDesignBody1TextBlock}"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0"
                           Opacity="0.5" />
            </StackPanel>

            <!-- Agent Details -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding SelectedAgent, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel Margin="24">
                    <!-- Agent Header -->
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="64" Height="64"
                                CornerRadius="12"
                                Background="{DynamicResource PrimaryHueLightBrush}"
                                Margin="0,0,16,0">
                            <materialDesign:PackIcon Kind="{Binding SelectedAgent.Icon}"
                                                     Width="36" Height="36"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedAgent.Name}"
                                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                                       FontWeight="Medium" />
                            <TextBlock Text="{Binding SelectedAgent.Description}"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       Opacity="0.7"
                                       TextWrapping="Wrap"
                                       MaxWidth="400" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding EditAgentCommand}"
                                    CommandParameter="{Binding SelectedAgent}"
                                    Content="Edit"
                                    Margin="0,0,8,0" />
                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding SetDefaultAgentCommand}"
                                    CommandParameter="{Binding SelectedAgent}"
                                    Content="Set Default"
                                    Margin="0,0,8,0" />
                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="Red"
                                    BorderBrush="Red"
                                    Command="{Binding DeleteAgentCommand}"
                                    CommandParameter="{Binding SelectedAgent}">
                                <materialDesign:PackIcon Kind="Delete" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Stats Cards -->
                    <UniformGrid Rows="1" Margin="0,0,0,24">
                        <materialDesign:Card Padding="16" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedAgent.TotalDocuments}"
                                           Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                                           Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                <TextBlock Text="Documents"
                                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                                           Opacity="0.7" />
                            </StackPanel>
                        </materialDesign:Card>
                        <materialDesign:Card Padding="16" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedAgent.TotalChunks}"
                                           Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                                           Foreground="{DynamicResource SecondaryHueMidBrush}" />
                                <TextBlock Text="Knowledge Chunks"
                                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                                           Opacity="0.7" />
                            </StackPanel>
                        </materialDesign:Card>
                    </UniformGrid>

                    <!-- Documents Section -->
                    <TextBlock Text="Documents"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                               Margin="0,0,0,12" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                Command="{Binding UploadDocumentCommand}"
                                Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Upload" Margin="0,0,8,0" />
                                <TextBlock Text="Upload File" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                Command="{Binding ShowPasteTextCommand}"
                                Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentPaste" Margin="0,0,8,0" />
                                <TextBlock Text="Paste Text" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                Command="{Binding ClearAllDocumentsCommand}"
                                Foreground="OrangeRed"
                                BorderBrush="OrangeRed"
                                Margin="0,0,8,0"
                                ToolTip="Delete all documents from this agent">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="DeleteSweep" Margin="0,0,8,0" />
                                <TextBlock Text="Clear All" />
                            </StackPanel>
                        </Button>

                        <!-- Help Button -->
                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="View supported file formats"
                                Click="ShowFormatHelp_Click">
                            <materialDesign:PackIcon Kind="HelpCircleOutline" />
                        </Button>
                    </StackPanel>

                    <!-- Data Format Help Section (collapsed by default) -->
                    <materialDesign:Card x:Name="FormatHelpCard"
                                         Visibility="Collapsed"
                                         Padding="16"
                                         Margin="0,0,0,16"
                                         Background="{DynamicResource MaterialDesignCardBackground}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <materialDesign:PackIcon Kind="FileDocument"
                                                         Width="24" Height="24"
                                                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                         Margin="0,0,8,0" />
                                <TextBlock Text="Supported File Formats"
                                           Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                           FontWeight="Medium"
                                           VerticalAlignment="Center" />
                                <Button Style="{StaticResource MaterialDesignIconButton}"
                                        Width="24" Height="24"
                                        Margin="8,0,0,0"
                                        Click="HideFormatHelp_Click">
                                    <materialDesign:PackIcon Kind="Close" Width="16" Height="16" />
                                </Button>
                            </StackPanel>

                            <!-- Format Grid -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Text Files -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                                    <TextBlock Text="Text Files" FontWeight="Medium" />
                                    <TextBlock Text=".txt, .md" Opacity="0.7" FontSize="12" />
                                </StackPanel>

                                <!-- Data Files -->
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8">
                                    <TextBlock Text="Data Files" FontWeight="Medium" />
                                    <TextBlock Text=".csv, .json" Opacity="0.7" FontSize="12" />
                                </StackPanel>

                                <!-- PDF -->
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
                                    <TextBlock Text="PDF Documents" FontWeight="Medium" />
                                    <TextBlock Text=".pdf" Opacity="0.7" FontSize="12" />
                                </StackPanel>

                                <!-- Word -->
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,8">
                                    <TextBlock Text="Word Documents" FontWeight="Medium" />
                                    <TextBlock Text=".doc, .docx" Opacity="0.7" FontSize="12" />
                                </StackPanel>

                                <!-- Excel -->
                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,8">
                                    <TextBlock Text="Excel Spreadsheets" FontWeight="Medium" />
                                    <TextBlock Text=".xls, .xlsx" Opacity="0.7" FontSize="12" />
                                </StackPanel>
                            </Grid>

                            <Separator Margin="0,0,0,12" />

                            <!-- Best Practices -->
                            <TextBlock Text="Data Format Best Practices"
                                       Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                       Margin="0,0,0,8" />

                            <StackPanel Margin="0,0,0,8">
                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="For Product Catalogs (CSV/Excel):" FontWeight="Medium" />
                                    <TextBlock Text="Include columns like: Product Name, SKU, Description, Price, Category, Stock"
                                               TextWrapping="Wrap" Opacity="0.8" />
                                </StackPanel>

                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="For Legal/Policy Documents (PDF/Word):" FontWeight="Medium" />
                                    <TextBlock Text="Use clear headings and structured paragraphs. Documents are split into chunks for better search."
                                               TextWrapping="Wrap" Opacity="0.8" />
                                </StackPanel>

                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="For FAQ/Knowledge Base (TXT/MD):" FontWeight="Medium" />
                                    <TextBlock Text="Format as Q: Question followed by A: Answer, or use markdown headers for topics."
                                               TextWrapping="Wrap" Opacity="0.8" />
                                </StackPanel>

                                <StackPanel>
                                    <TextBlock Text="For JSON Data:" FontWeight="Medium" />
                                    <TextBlock Text="Use arrays of objects with descriptive field names. Each object is processed separately."
                                               TextWrapping="Wrap" Opacity="0.8" />
                                </StackPanel>
                            </StackPanel>

                            <Separator Margin="0,8,0,12" />

                            <!-- Example -->
                            <TextBlock Text="Example: Product CSV Format"
                                       Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                       Margin="0,0,0,8" />

                            <Border Background="#1E1E1E"
                                    CornerRadius="4"
                                    Padding="12">
                                <TextBlock FontFamily="Consolas"
                                           FontSize="11"
                                           Foreground="#D4D4D4">
                                    <Run Text="ProductName,SKU,Price,Description" />
                                    <LineBreak />
                                    <Run Text="Widget Pro,WP-001,29.99,Premium widget" />
                                    <LineBreak />
                                    <Run Text="Gadget Plus,GP-002,49.99,Advanced gadget" />
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Documents List -->
                    <ItemsControl ItemsSource="{Binding SelectedAgent.Documents}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <materialDesign:Card Margin="0,0,0,8" Padding="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <materialDesign:PackIcon Grid.Column="0"
                                                                 Kind="FileDocument"
                                                                 Width="24" Height="24"
                                                                 Margin="0,0,12,0"
                                                                 VerticalAlignment="Center"
                                                                 Foreground="{DynamicResource PrimaryHueMidBrush}" />

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FileName}"
                                                       FontWeight="Medium" />
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding FileSizeFormatted}"
                                                           FontSize="12"
                                                           Opacity="0.7" />
                                                <TextBlock Text=" | " Opacity="0.5" />
                                                <TextBlock FontSize="12" Opacity="0.7">
                                                    <Run Text="{Binding ChunkCount, Mode=OneWay}" />
                                                    <Run Text="chunks" />
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Status -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                                            <ProgressBar IsIndeterminate="True"
                                                         Width="20" Height="20"
                                                         Margin="0,0,8,0">
                                                <ProgressBar.Style>
                                                    <Style TargetType="ProgressBar" BasedOn="{StaticResource MaterialDesignCircularProgressBar}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Processing">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ProgressBar.Style>
                                            </ProgressBar>

                                            <materialDesign:Chip Height="24" FontSize="11">
                                                <materialDesign:Chip.Style>
                                                    <Style TargetType="materialDesign:Chip">
                                                        <Setter Property="Content" Value="{Binding StatusText}" />
                                                        <Setter Property="Background" Value="Gray" />
                                                        <Setter Property="Foreground" Value="White" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                                <Setter Property="Background" Value="#4CAF50" />
                                                                <Setter Property="Content" Value="Ready" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Processing">
                                                                <Setter Property="Background" Value="#2196F3" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                <Setter Property="Background" Value="#F44336" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </materialDesign:Chip.Style>
                                            </materialDesign:Chip>
                                        </StackPanel>

                                        <!-- Actions -->
                                        <StackPanel Grid.Column="3" Orientation="Horizontal">
                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                    Command="{Binding DataContext.ReprocessDocumentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Reprocess">
                                                <materialDesign:PackIcon Kind="Refresh" />
                                            </Button>
                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                    Command="{Binding DataContext.DeleteDocumentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Delete">
                                                <materialDesign:PackIcon Kind="Delete" Foreground="Red" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </materialDesign:Card>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty Documents State -->
                    <TextBlock Text="No documents uploaded yet. Upload documents to give this agent knowledge."
                               Opacity="0.5"
                               Margin="0,16,0,0"
                               TextAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignBody2TextBlock}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedAgent.Documents.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Agent Editor Dialog -->
        <materialDesign:DialogHost IsOpen="{Binding ShowAgentEditor}"
                                   Grid.ColumnSpan="2"
                                   DialogTheme="Inherit">
            <materialDesign:DialogHost.DialogContent>
                <materialDesign:Card Width="500" Padding="24">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                                   Margin="0,0,0,24">
                            <TextBlock.Text>
                                <Binding Path="IsNewAgent">
                                    <Binding.Converter>
                                        <BooleanToVisibilityConverter />
                                    </Binding.Converter>
                                </Binding>
                            </TextBlock.Text>
                        </TextBlock>

                        <TextBlock Text="Create New Agent"
                                   Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                                   Visibility="{Binding IsNewAgent, Converter={StaticResource BoolToVis}}"
                                   Margin="0,0,0,24" />

                        <TextBlock Text="Edit Agent"
                                   Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                                   Visibility="{Binding IsNewAgent, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                   Margin="0,0,0,24" />

                        <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Agent Name"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,16" />

                        <TextBox Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Description"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 TextWrapping="Wrap"
                                 MinHeight="60"
                                 Margin="0,0,0,16" />

                        <ComboBox ItemsSource="{Binding AvailableIcons}"
                                  SelectedItem="{Binding EditIcon}"
                                  materialDesign:HintAssist.Hint="Icon"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  Margin="0,0,0,16">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="{Binding}" Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBox Text="{Binding EditSystemPrompt, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="System Prompt"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="120"
                                 MaxHeight="200"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,16" />

                        <CheckBox Content="Enabled"
                                  IsChecked="{Binding EditIsEnabled}"
                                  Margin="0,0,0,24" />

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancel"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Command="{Binding CancelEditCommand}"
                                    Margin="0,0,8,0" />
                            <Button Content="Save"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Command="{Binding SaveAgentCommand}" />
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>
            </materialDesign:DialogHost.DialogContent>
        </materialDesign:DialogHost>

        <!-- Paste Text Dialog -->
        <materialDesign:DialogHost IsOpen="{Binding ShowPasteDialog}"
                                   Grid.ColumnSpan="2"
                                   DialogTheme="Inherit">
            <materialDesign:DialogHost.DialogContent>
                <materialDesign:Card Width="700" MaxHeight="650" Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="Paste Data"
                                       Style="{StaticResource MaterialDesignHeadline5TextBlock}" />
                            <TextBlock Text="Paste your text data directly - products, FAQs, or any content"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       Opacity="0.7" />
                        </StackPanel>

                        <!-- Options Row -->
                        <Grid Grid.Row="1" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     Text="{Binding PasteDocumentName, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Document Name"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Margin="0,0,16,0" />

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <RadioButton Content="Append"
                                             IsChecked="{Binding PasteOverwrite, Converter={StaticResource InverseBooleanConverter}}"
                                             GroupName="PasteMode"
                                             Margin="0,0,16,0"
                                             ToolTip="Add to existing documents" />
                                <RadioButton Content="Overwrite"
                                             IsChecked="{Binding PasteOverwrite}"
                                             GroupName="PasteMode"
                                             Foreground="OrangeRed"
                                             ToolTip="Replace all existing documents" />
                            </StackPanel>
                        </Grid>

                        <!-- Text Input with Instructions Side by Side -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="250" />
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     Text="{Binding PasteText, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Paste your data here..."
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="300"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Margin="0,0,16,0" />

                            <!-- Instructions Panel -->
                            <Border Grid.Column="1"
                                    Background="{DynamicResource MaterialDesignCardBackground}"
                                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="12">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBlock Text="{Binding PasteInstructions}"
                                               TextWrapping="Wrap"
                                               FontSize="11"
                                               FontFamily="Consolas"
                                               Opacity="0.8" />
                                </ScrollViewer>
                            </Border>
                        </Grid>

                        <!-- Character Count -->
                        <TextBlock Grid.Row="3"
                                   Margin="0,8,0,0"
                                   Opacity="0.6"
                                   FontSize="12">
                            <Run Text="Characters: " />
                            <Run Text="{Binding PasteText.Length, Mode=OneWay, FallbackValue=0}" />
                        </TextBlock>

                        <!-- Actions -->
                        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                            <Button Content="Cancel"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Command="{Binding CancelPasteCommand}"
                                    Margin="0,0,8,0" />
                            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                    Command="{Binding ProcessPastedTextCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Check" Margin="0,0,8,0" />
                                    <TextBlock Text="Process &amp; Save" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>
            </materialDesign:DialogHost.DialogContent>
        </materialDesign:DialogHost>

        <!-- Loading Overlay -->
        <Border Grid.ColumnSpan="2"
                Background="#80000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True"
                             Width="48" Height="48" />
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="White"
                           Margin="0,16,0,0"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
