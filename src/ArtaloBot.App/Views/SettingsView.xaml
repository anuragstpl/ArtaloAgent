<UserControl x:Class="ArtaloBot.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:ArtaloBot.App.Converters"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="800"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="24,20">
        <StackPanel MaxWidth="700">

            <!-- Header -->
            <TextBlock Text="Settings"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,24" />

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- LLM Providers Section                                   -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <TextBlock Text="LLM Providers"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,12" />

            <ItemsControl ItemsSource="{Binding Providers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Provider Header -->
                                <Grid Grid.Row="0" Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Icon -->
                                    <Border Grid.Column="0"
                                            Width="44" Height="44"
                                            Background="{StaticResource AccentLightBrush}"
                                            CornerRadius="8"
                                            Margin="0,0,14,0">
                                        <materialDesign:PackIcon Kind="{Binding Icon}"
                                                                 Width="22" Height="22"
                                                                 Foreground="{StaticResource AccentBrush}"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center" />
                                    </Border>

                                    <!-- Info -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Text="{Binding ConnectionStatus}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>

                                    <!-- Toggle -->
                                    <ToggleButton Grid.Column="2"
                                                  IsChecked="{Binding IsEnabled}"
                                                  Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                                </Grid>

                                <!-- API Key -->
                                <Grid Grid.Row="1" Margin="0,0,0,12"
                                      Visibility="{Binding RequiresApiKey, Converter={StaticResource BoolToVis}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Text="API Key"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,0,0,6" />
                                    <TextBox Grid.Row="1"
                                             Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource Win11TextBox}"
                                             Height="40" />
                                </Grid>

                                <!-- Base URL -->
                                <Grid Grid.Row="2" Margin="0,0,0,12"
                                      Visibility="{Binding HasBaseUrl, Converter={StaticResource BoolToVis}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Text="Base URL"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,0,0,6" />
                                    <TextBox Grid.Row="1"
                                             Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource Win11TextBox}"
                                             Height="40" />
                                </Grid>

                                <!-- Test Button -->
                                <Button Grid.Row="3"
                                        Style="{StaticResource Win11SecondaryButton}"
                                        Command="{Binding DataContext.TestConnectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        HorizontalAlignment="Left"
                                        Height="36"
                                        Padding="16,0">
                                    <StackPanel Orientation="Horizontal">
                                        <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                                     IsIndeterminate="True"
                                                     Width="14" Height="14"
                                                     Margin="0,0,8,0"
                                                     Visibility="{Binding IsTestingConnection, Converter={StaticResource BoolToVis}}" />
                                        <TextBlock Text="Test Connection" FontSize="13" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- Default Settings Section                                -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <TextBlock Text="Default Settings"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,24,0,12" />

            <Border Style="{StaticResource SettingsCard}">
                <StackPanel>
                    <!-- Temperature -->
                    <Grid Margin="0,0,0,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="60" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                   Text="Temperature"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,10" />

                        <Slider Grid.Row="1" Grid.Column="0"
                                Value="{Binding DefaultSettings.Temperature}"
                                Minimum="0" Maximum="2"
                                TickFrequency="0.1"
                                IsSnapToTickEnabled="True"
                                Margin="0,0,16,0" />

                        <Border Grid.Row="1" Grid.Column="1"
                                Background="{StaticResource BackgroundBrush}"
                                CornerRadius="4"
                                Padding="8,4">
                            <TextBlock Text="{Binding DefaultSettings.Temperature, StringFormat=N1}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" />
                        </Border>
                    </Grid>

                    <!-- Max Tokens -->
                    <Grid Margin="0,0,0,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="Max Tokens"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,6" />
                        <TextBox Grid.Row="1"
                                 Text="{Binding DefaultSettings.MaxTokens}"
                                 Style="{StaticResource Win11TextBox}"
                                 Height="40"
                                 Width="200"
                                 HorizontalAlignment="Left" />
                    </Grid>

                    <!-- System Prompt -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="System Prompt"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,6" />
                        <TextBox Grid.Row="1"
                                 Text="{Binding DefaultSettings.SystemPrompt, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Win11TextBox}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="100"
                                 MaxHeight="160"
                                 VerticalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top"
                                 Padding="12,10" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- Memory Section                                          -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Grid Margin="0,28,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="BrainFreeze"
                                            Width="18" Height="18"
                                            Foreground="{StaticResource AccentBrush}"
                                            VerticalAlignment="Center"
                                            Margin="0,0,8,0" />
                    <TextBlock Text="Conversation Memory"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Memory count badge -->
                <Border Grid.Column="1"
                        Background="{StaticResource AccentLightBrush}"
                        CornerRadius="12"
                        Padding="10,4">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Database"
                                                Width="13" Height="13"
                                                Foreground="{StaticResource AccentBrush}"
                                                VerticalAlignment="Center"
                                                Margin="0,0,5,0" />
                        <TextBlock FontSize="12" Foreground="{StaticResource AccentBrush}">
                            <Run Text="{Binding TotalMemoryCount}" />
                            <Run Text=" stored" />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource SettingsCard}">
                <StackPanel>

                    <!-- Enable Memory Toggle -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Enable Vector Memory"
                                       FontSize="14"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock TextWrapping="Wrap"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,4,16,0">
                                Stores each message as a vector embedding and retrieves
                                semantically relevant context before each LLM call.
                            </TextBlock>
                        </StackPanel>

                        <ToggleButton Grid.Column="1"
                                      IsChecked="{Binding MemorySettings.IsEnabled}"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      VerticalAlignment="Center" />
                    </Grid>

                    <Separator Margin="0,0,0,20" Opacity="0.15" />

                    <!-- Embedding Provider -->
                    <Grid Margin="0,0,0,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Embedding Provider"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,4" />
                        <TextBlock Grid.Row="1"
                                   TextWrapping="Wrap"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Opacity="0.7"
                                   Margin="0,0,0,8">
                            <Run Text="simple" FontWeight="SemiBold" /> — built-in TF-IDF, no API needed.&#x0a;<Run Text="ollama" FontWeight="SemiBold" /> — uses local Ollama /api/embeddings.&#x0a;<Run Text="openai" FontWeight="SemiBold" /> — uses OpenAI text-embedding models.
                        </TextBlock>
                        <ComboBox Grid.Row="2"
                                  ItemsSource="{Binding EmbeddingProviders}"
                                  SelectedItem="{Binding MemorySettings.EmbeddingProvider}"
                                  Height="40"
                                  HorizontalAlignment="Left"
                                  Width="220" />
                    </Grid>

                    <!-- Embedding Model -->
                    <Grid Margin="0,0,0,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="Embedding Model"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,6" />
                        <TextBox Grid.Row="1"
                                 Text="{Binding MemorySettings.EmbeddingModel, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Win11TextBox}"
                                 Height="40"
                                 Width="320"
                                 HorizontalAlignment="Left" />
                    </Grid>

                    <Separator Margin="0,0,0,20" Opacity="0.15" />

                    <!-- Similarity Threshold -->
                    <Grid Margin="0,0,0,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="60" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                   Text="Similarity Threshold"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,4" />
                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                                   Text="Minimum cosine similarity (0.0–1.0) for a memory to be included in the context."
                                   FontSize="11"
                                   Opacity="0.7"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />

                        <Slider Grid.Row="2" Grid.Column="0"
                                Value="{Binding MemorySettings.SimilarityThreshold}"
                                Minimum="0" Maximum="1"
                                TickFrequency="0.05"
                                IsSnapToTickEnabled="True"
                                Margin="0,0,16,0" />

                        <Border Grid.Row="2" Grid.Column="1"
                                Background="{StaticResource BackgroundBrush}"
                                CornerRadius="4"
                                Padding="8,4">
                            <TextBlock Text="{Binding MemorySettings.SimilarityThreshold, StringFormat=N2}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" />
                        </Border>
                    </Grid>

                    <!-- Max Memories to Inject & Total Max -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Max to inject -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Max memories to inject per request"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,6" />
                            <TextBox Text="{Binding MemorySettings.MaxMemoriesToInject}"
                                     Style="{StaticResource Win11TextBox}"
                                     Height="40" />
                        </StackPanel>

                        <!-- Max total stored -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Max total memories stored"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,6" />
                            <TextBox Text="{Binding MemorySettings.MaxMemories}"
                                     Style="{StaticResource Win11TextBox}"
                                     Height="40" />
                        </StackPanel>
                    </Grid>

                    <!-- Store Globally Toggle -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Store Memories Globally"
                                       FontSize="14"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Memories persist across all chat sessions (recommended)."
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,16,0" />
                        </StackPanel>

                        <ToggleButton Grid.Column="1"
                                      IsChecked="{Binding MemorySettings.StoreGlobally}"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      VerticalAlignment="Center" />
                    </Grid>

                    <!-- Cross-session Memory Toggle -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Search All Memories"
                                       FontSize="14"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Search all stored memories regardless of session (recommended)."
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,16,0" />
                        </StackPanel>

                        <ToggleButton Grid.Column="1"
                                      IsChecked="{Binding MemorySettings.CrossSessionMemory}"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      VerticalAlignment="Center" />
                    </Grid>

                    <Separator Margin="0,0,0,16" Opacity="0.15" />

                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                        <Button Style="{StaticResource Win11SecondaryButton}"
                                Command="{Binding TestEmbeddingCommand}"
                                Height="36"
                                Padding="16,0"
                                Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="TestTube"
                                                        Width="15" Height="15"
                                                        Margin="0,0,7,0"
                                                        VerticalAlignment="Center" />
                                <TextBlock Text="Test Embedding" FontSize="13" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource Win11SecondaryButton}"
                                Command="{Binding ClearAllMemoriesCommand}"
                                Height="36"
                                Padding="16,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="DatabaseRemove"
                                                        Width="15" Height="15"
                                                        Margin="0,0,7,0"
                                                        Foreground="#E05252"
                                                        VerticalAlignment="Center" />
                                <TextBlock Text="Clear All Memories" FontSize="13" Foreground="#E05252" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- Save Button                                             -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Button Style="{StaticResource Win11PrimaryButton}"
                    Command="{Binding SaveSettingsCommand}"
                    Margin="0,24,0,0"
                    HorizontalAlignment="Left"
                    Height="40"
                    Padding="24,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0,0,8,0" />
                    <TextBlock Text="Save Settings" />
                </StackPanel>
            </Button>

            <!-- Status -->
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="13"
                       Foreground="#107C10"
                       Margin="0,12,0,20" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
