<UserControl x:Class="ArtaloBot.App.Views.ChannelsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:ArtaloBot.App.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24">
            <!-- Header -->
            <TextBlock Text="Communication Channels"
                       Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                       Margin="0,0,0,8" />

            <TextBlock Text="Connect ArtaloBot to external messaging platforms"
                       Style="{StaticResource MaterialDesignBody1TextBlock}"
                       Opacity="0.7"
                       Margin="0,0,0,24" />

            <!-- Channels List -->
            <ItemsControl ItemsSource="{Binding Channels}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <materialDesign:Card Style="{StaticResource SettingsCard}"
                                             Margin="0,0,0,16"
                                             IsEnabled="{Binding IsComingSoon, Converter={StaticResource InverseBoolToVis}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <Grid Grid.Row="0" Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <materialDesign:PackIcon Grid.Column="0"
                                                             Kind="{Binding Icon}"
                                                             Width="40" Height="40"
                                                             VerticalAlignment="Center"
                                                             Margin="0,0,16,0"
                                                             Foreground="{DynamicResource PrimaryHueMidBrush}" />

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}"
                                                       Style="{StaticResource MaterialDesignHeadline6TextBlock}" />
                                            <materialDesign:Chip Content="Coming Soon"
                                                                 Margin="8,0,0,0"
                                                                 Visibility="{Binding IsComingSoon, Converter={StaticResource BoolToVis}}"
                                                                 Background="{DynamicResource SecondaryHueMidBrush}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}"
                                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                   Opacity="0.7" />
                                    </StackPanel>

                                    <!-- Connection Status -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="CheckCircle"
                                                                 Width="24" Height="24"
                                                                 Foreground="Green"
                                                                 Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}"
                                                                 Margin="0,0,8,0" />
                                        <ToggleButton IsChecked="{Binding IsEnabled}"
                                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                                      IsEnabled="{Binding IsComingSoon, Converter={StaticResource InverseBoolToVis}}" />
                                    </StackPanel>
                                </Grid>

                                <!-- Configuration Fields -->
                                <ItemsControl Grid.Row="1"
                                              ItemsSource="{Binding ConfigurationFields}"
                                              Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVis}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                     materialDesign:HintAssist.Hint="{Binding Label}"
                                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                     Margin="0,0,0,12" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Action Buttons -->
                                <StackPanel Grid.Row="2"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVis}}">
                                    <Button Content="Save"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Command="{Binding DataContext.SaveChannelConfigCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Margin="0,0,8,0" />

                                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                            Command="{Binding DataContext.ConnectChannelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding IsConnected, Converter={StaticResource InverseBoolToVis}}"
                                            IsEnabled="{Binding IsConnecting, Converter={StaticResource InverseBoolToVis}}">
                                        <StackPanel Orientation="Horizontal">
                                            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                                         IsIndeterminate="True"
                                                         Width="16" Height="16"
                                                         Margin="0,0,8,0"
                                                         Visibility="{Binding IsConnecting, Converter={StaticResource BoolToVis}}" />
                                            <TextBlock Text="Connect" />
                                        </StackPanel>
                                    </Button>

                                    <Button Content="Disconnect"
                                            Style="{StaticResource MaterialDesignOutlinedSecondaryButton}"
                                            Command="{Binding DataContext.DisconnectChannelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Grid>
                        </materialDesign:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Status Message -->
            <TextBlock Text="{Binding StatusMessage}"
                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                       Margin="0,16,0,0"
                       Foreground="{DynamicResource SecondaryHueMidBrush}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
