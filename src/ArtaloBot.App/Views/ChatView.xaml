<UserControl x:Class="ArtaloBot.App.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:ArtaloBot.App.Converters"
             xmlns:markdig="clr-namespace:Markdig.Wpf;assembly=Markdig.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="800"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />

        <!-- Markdown Viewer Style -->
        <Style TargetType="FlowDocument" x:Key="MarkdownDocument">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="PagePadding" Value="0" />
        </Style>

        <!-- Markdown Heading Styles -->
        <Style TargetType="Paragraph" x:Key="Heading1Style">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,8,0,8" />
        </Style>
        <Style TargetType="Paragraph" x:Key="Heading2Style">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,6,0,6" />
        </Style>
        <Style TargetType="Paragraph" x:Key="Heading3Style">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,4,0,4" />
        </Style>

        <!-- Code Block Style -->
        <Style TargetType="Section" x:Key="CodeBlockStyle">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,8,0,8" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Chat"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />

                <!-- Provider Selector -->
                <ComboBox Grid.Row="0" Grid.Column="1"
                          ItemsSource="{Binding AvailableProviders}"
                          SelectedItem="{Binding SelectedProvider}"
                          MinWidth="120"
                          Height="36"
                          Margin="0,0,12,0"
                          Padding="12,0"
                          FontSize="13"
                          VerticalContentAlignment="Center" />

                <!-- Model Selector -->
                <ComboBox Grid.Row="0" Grid.Column="2"
                          ItemsSource="{Binding AvailableModels}"
                          SelectedItem="{Binding SelectedModel}"
                          MinWidth="160"
                          Height="36"
                          Margin="0,0,12,0"
                          Padding="12,0"
                          FontSize="13"
                          VerticalContentAlignment="Center" />

                <!-- Clear Button -->
                <Button Grid.Row="0" Grid.Column="3"
                        Style="{StaticResource Win11IconButton}"
                        ToolTip="Clear Chat"
                        Command="{Binding ClearChatCommand}">
                    <materialDesign:PackIcon Kind="Broom" Width="20" Height="20"
                                             Foreground="{StaticResource TextSecondaryBrush}" />
                </Button>

                <!-- Agent Knowledge Selector (Second Row) -->
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                            Orientation="Horizontal"
                            Margin="0,10,0,0">

                    <!-- Agent Icon -->
                    <materialDesign:PackIcon Kind="Robot"
                                             Width="20" Height="20"
                                             Foreground="{StaticResource AccentBrush}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,8,0" />

                    <!-- Agent Label -->
                    <TextBlock Text="Knowledge Source:"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0" />

                    <!-- Agent Selector -->
                    <ComboBox ItemsSource="{Binding AvailableAgents}"
                              SelectedItem="{Binding SelectedAgent}"
                              MinWidth="180"
                              Height="32"
                              Padding="10,0"
                              FontSize="13"
                              VerticalContentAlignment="Center"
                              materialDesign:HintAssist.Hint="None (General Chat)">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Robot"
                                                             Width="16" Height="16"
                                                             Margin="0,0,8,0"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Clear Agent Selection -->
                    <Button Style="{StaticResource Win11IconButton}"
                            ToolTip="Clear agent selection"
                            Command="{Binding ClearAgentCommand}"
                            Visibility="{Binding UseAgentKnowledge, Converter={StaticResource BoolToVis}}"
                            Margin="4,0,0,0"
                            Height="32" Width="32">
                        <materialDesign:PackIcon Kind="Close" Width="16" Height="16"
                                                 Foreground="{StaticResource TextSecondaryBrush}" />
                    </Button>

                    <!-- Agent Status Indicator -->
                    <Border Visibility="{Binding UseAgentKnowledge, Converter={StaticResource BoolToVis}}"
                            Background="{StaticResource AccentLightBrush}"
                            CornerRadius="4"
                            Padding="8,4"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Database"
                                                     Width="14" Height="14"
                                                     Foreground="{StaticResource AccentBrush}"
                                                     Margin="0,0,6,0" />
                            <TextBlock Text="Knowledge Active"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Messages Area -->
        <ScrollViewer Grid.Row="1"
                      x:Name="MessagesScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="20,16">
            <ItemsControl ItemsSource="{Binding Messages}"
                          x:Name="MessagesItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,6">
                            <!-- User Message -->
                            <Border Style="{StaticResource UserMessageBubble}"
                                    Visibility="{Binding IsUser, Converter={StaticResource BoolToVis}}">
                                <TextBox Text="{Binding Content, Mode=OneWay}"
                                         IsReadOnly="True"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="White"
                                         TextWrapping="Wrap"
                                         FontSize="14"
                                         Padding="0"
                                         Cursor="IBeam"
                                         ContextMenu="{x:Null}" />
                            </Border>

                            <!-- Assistant Message -->
                            <Border Style="{StaticResource AssistantMessageBubble}"
                                    Visibility="{Binding IsAssistant, Converter={StaticResource BoolToVis}}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- AI Label -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Background="{StaticResource AccentBrush}"
                                                CornerRadius="4"
                                                Padding="6,2">
                                            <TextBlock Text="AI" FontSize="11" FontWeight="SemiBold" Foreground="White" />
                                        </Border>
                                        <TextBlock Text="{Binding Model}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>

                                    <!-- Message Content with Markdown Rendering -->
                                    <markdig:MarkdownViewer Grid.Row="1"
                                                            Markdown="{Binding Content, Mode=OneWay}">
                                        <markdig:MarkdownViewer.Resources>
                                            <Style TargetType="FlowDocument">
                                                <Setter Property="FontFamily" Value="Segoe UI" />
                                                <Setter Property="FontSize" Value="14" />
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                <Setter Property="PagePadding" Value="0" />
                                            </Style>
                                            <Style TargetType="Paragraph">
                                                <Setter Property="Margin" Value="0,0,0,8" />
                                            </Style>
                                            <Style TargetType="List">
                                                <Setter Property="Margin" Value="16,4,0,8" />
                                                <Setter Property="Padding" Value="0" />
                                            </Style>
                                            <Style TargetType="ListItem">
                                                <Setter Property="Margin" Value="0,2,0,2" />
                                            </Style>
                                        </markdig:MarkdownViewer.Resources>
                                    </markdig:MarkdownViewer>

                                    <!-- Streaming Indicator -->
                                    <StackPanel Grid.Row="2"
                                                Orientation="Horizontal"
                                                Margin="0,8,0,0"
                                                Visibility="{Binding IsStreaming, Converter={StaticResource BoolToVis}}">
                                        <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                                     IsIndeterminate="True"
                                                     Width="14" Height="14"
                                                     Foreground="{StaticResource AccentBrush}"
                                                     Margin="0,0,8,0" />
                                        <TextBlock Text="Generating..."
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty State -->
        <StackPanel Grid.Row="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Visibility="{Binding HasMessages, Converter={StaticResource InverseBoolToVis}}">

            <Border Width="80" Height="80"
                    Background="{StaticResource AccentLightBrush}"
                    CornerRadius="20"
                    Margin="0,0,0,20">
                <materialDesign:PackIcon Kind="Robot"
                                         Width="40" Height="40"
                                         Foreground="{StaticResource AccentBrush}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center" />
            </Border>

            <TextBlock Text="How can I help you today?"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8" />

            <TextBlock Text="Type a message to start chatting"
                       FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Input Area -->
        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Input Box -->
                <TextBox Grid.Column="0"
                         x:Name="InputTextBox"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource Win11TextBox}"
                         Height="44"
                         VerticalContentAlignment="Center"
                         Margin="0,0,12,0">
                    <TextBox.InputBindings>
                        <!-- Enter: Queue message with debounce (allows multiple messages) -->
                        <KeyBinding Key="Return" Command="{Binding SendMessageCommand}" />
                        <!-- Shift+Enter: Send immediately -->
                        <KeyBinding Key="Return" Modifiers="Shift" Command="{Binding SendMessageImmediateCommand}" />
                    </TextBox.InputBindings>
                </TextBox>

                <!-- Send Button (sends immediately) -->
                <Button Grid.Column="1"
                        Style="{StaticResource Win11PrimaryButton}"
                        Command="{Binding SendMessageImmediateCommand}"
                        IsEnabled="{Binding IsStreaming, Converter={StaticResource InverseBoolToVis}}"
                        Width="100"
                        Height="44"
                        ToolTip="Send immediately (Shift+Enter)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Send" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <materialDesign:PackIcon Kind="Send" Width="18" Height="18" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Status Bar (when streaming) -->
        <Border Grid.Row="2"
                VerticalAlignment="Top"
                Margin="20,-40,20,0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,8"
                Visibility="{Binding IsStreaming, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 IsIndeterminate="True"
                                 Width="16" Height="16"
                                 Foreground="{StaticResource AccentBrush}"
                                 Margin="0,0,10,0" />
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Button Grid.Column="1"
                        Style="{StaticResource Win11SecondaryButton}"
                        Command="{Binding StopGenerationCommand}"
                        Padding="12,6"
                        Height="32">
                    <TextBlock Text="Stop" FontSize="12" />
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
