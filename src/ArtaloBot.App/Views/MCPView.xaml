<UserControl x:Class="ArtaloBot.App.Views.MCPView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="900"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="MCP Servers (Skills)"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="Configure external tools via Model Context Protocol"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,4,0,0" />
                </StackPanel>

                <Button Grid.Column="1"
                        Style="{StaticResource Win11PrimaryButton}"
                        Command="{Binding StartAddNewCommand}"
                        Height="40"
                        Padding="20,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,8,0" />
                        <TextBlock Text="Add Server" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Server List -->
            <Border Grid.Column="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ListBox Grid.Row="0"
                             ItemsSource="{Binding Servers}"
                             SelectedItem="{Binding SelectedServer}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="8">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,8" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="border"
                                                    Background="{StaticResource BackgroundBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="12">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource AccentBrush}" />
                                                    <Setter Property="BorderThickness" TargetName="border" Value="2" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" TargetName="border" Value="{StaticResource SurfaceLightBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Text="{Binding StatusText}"
                                                   FontSize="12"
                                                   Foreground="{Binding StatusColor}"
                                                   Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,4,0,0"
                                                   Visibility="{Binding Description, Converter={StaticResource NullToVisibilityConverter}}" />
                                    </StackPanel>

                                    <!-- Status indicator -->
                                    <Ellipse Grid.Column="1"
                                             Width="12" Height="12"
                                             Fill="{Binding StatusColor}"
                                             VerticalAlignment="Top"
                                             Margin="8,4,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Status bar -->
                    <Border Grid.Row="1"
                            Background="{StaticResource BackgroundBrush}"
                            Padding="12,8">
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </Border>
                </Grid>
            </Border>

            <!-- Server Details Panel -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="24,20">
                <Grid>
                    <!-- No selection state -->
                    <StackPanel Visibility="{Binding SelectedServer, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="ServerNetwork"
                                                 Width="64" Height="64"
                                                 Foreground="{StaticResource TextSecondaryBrush}"
                                                 HorizontalAlignment="Center"
                                                 Opacity="0.5" />
                        <TextBlock Text="Select a server to view details"
                                   FontSize="16"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,16,0,0" />
                        <TextBlock Text="or click 'Add Server' to create a new one"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"
                                   Opacity="0.7" />
                    </StackPanel>

                    <!-- Server details (when selected) -->
                    <StackPanel Visibility="{Binding SelectedServer, Converter={StaticResource BoolToVisibilityConverter}}"
                                DataContext="{Binding SelectedServer}"
                                MaxWidth="600">

                    <!-- Server Header -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Name}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Ellipse Width="10" Height="10"
                                         Fill="{Binding StatusColor}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,8,0" />
                                <TextBlock Text="{Binding StatusText}"
                                           FontSize="13"
                                           Foreground="{Binding StatusColor}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <!-- Connect/Disconnect -->
                            <Button Style="{StaticResource Win11PrimaryButton}"
                                    Command="{Binding DataContext.ConnectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Visibility="{Binding IsConnected, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                    Height="36"
                                    Padding="16,0"
                                    Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                                 IsIndeterminate="True"
                                                 Width="14" Height="14"
                                                 Margin="0,0,8,0"
                                                 Visibility="{Binding IsConnecting, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <TextBlock Text="Connect" />
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource Win11SecondaryButton}"
                                    Command="{Binding DataContext.DisconnectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Height="36"
                                    Padding="16,0"
                                    Margin="0,0,8,0">
                                <TextBlock Text="Disconnect" />
                            </Button>

                            <Button Style="{StaticResource Win11SecondaryButton}"
                                    Command="{Binding DataContext.StartEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Height="36"
                                    Padding="16,0"
                                    Margin="0,0,8,0">
                                <materialDesign:PackIcon Kind="Pencil" Width="16" Height="16" />
                            </Button>

                            <Button Style="{StaticResource Win11SecondaryButton}"
                                    Command="{Binding DataContext.DeleteServerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Height="36"
                                    Padding="16,0"
                                    Foreground="#D13438">
                                <materialDesign:PackIcon Kind="Delete" Width="16" Height="16" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Configuration Info -->
                    <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Configuration"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,12" />

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Command:"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Command}"
                                           FontSize="12"
                                           FontFamily="Consolas"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Arguments:"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Arguments}"
                                           FontSize="12"
                                           FontFamily="Consolas"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Available Tools -->
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="Available Tools"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,12" />

                            <TextBlock Text="Connect to the server to see available tools"
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Visibility="{Binding IsConnected, Converter={StaticResource InverseBoolToVisibilityConverter}}" />

                            <ItemsControl ItemsSource="{Binding Tools}"
                                          Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource BackgroundBrush}"
                                                CornerRadius="6"
                                                Padding="12"
                                                Margin="0,0,0,8">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource AccentBrush}" />
                                                        <TextBlock Text="{Binding Description}"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,4,0,0" />
                                                        <TextBlock Text="{Binding InputSchemaDescription}"
                                                                   FontSize="11"
                                                                   FontFamily="Consolas"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   Margin="0,4,0,0"
                                                                   Opacity="0.7" />
                                                    </StackPanel>

                                                    <Button Grid.Column="1"
                                                            Style="{StaticResource Win11SecondaryButton}"
                                                            Command="{Binding DataContext.TestToolCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Height="32"
                                                            Padding="12,0"
                                                            VerticalAlignment="Top">
                                                        <TextBlock Text="Test" FontSize="12" />
                                                    </Button>
                                                </Grid>

                                                <!-- Test Arguments -->
                                                <Expander Header="Test Arguments" Margin="0,8,0,0">
                                                    <StackPanel Margin="0,8,0,0">
                                                        <TextBox Text="{Binding TestArguments, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource Win11TextBox}"
                                                                 FontFamily="Consolas"
                                                                 AcceptsReturn="True"
                                                                 MinHeight="60"
                                                                 MaxHeight="120"
                                                                 TextWrapping="Wrap"
                                                                 VerticalScrollBarVisibility="Auto" />

                                                        <TextBlock Text="Result:"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   Margin="0,8,0,4"
                                                                   Visibility="{Binding TestResult, Converter={StaticResource NullToVisibilityConverter}}" />
                                                        <Border Background="{StaticResource SurfaceBrush}"
                                                                CornerRadius="4"
                                                                Padding="8"
                                                                Visibility="{Binding TestResult, Converter={StaticResource NullToVisibilityConverter}}">
                                                            <TextBlock Text="{Binding TestResult}"
                                                                       FontSize="12"
                                                                       FontFamily="Consolas"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       TextWrapping="Wrap" />
                                                        </Border>
                                                    </StackPanel>
                                                </Expander>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- Edit Dialog Overlay -->
        <Border Grid.RowSpan="2"
                Background="#80000000"
                Visibility="{Binding EditingServer, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="12"
                    Width="500"
                    MaxHeight="600"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Padding="24">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel DataContext="{Binding EditingServer}">
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,20">
                            <TextBlock.Text>
                                <Binding Path="DataContext.IsAddingNew"
                                         RelativeSource="{RelativeSource AncestorType=UserControl}"
                                         Converter="{StaticResource BoolToVisibilityConverter}"
                                         ConverterParameter="Add New Server|Edit Server" />
                            </TextBlock.Text>
                        </TextBlock>

                        <!-- Name -->
                        <TextBlock Text="Server Name" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Win11TextBox}"
                                 Height="40"
                                 Margin="0,0,0,16" />

                        <!-- Description -->
                        <TextBlock Text="Description" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Win11TextBox}"
                                 Height="40"
                                 Margin="0,0,0,16" />

                        <!-- Command -->
                        <TextBlock Text="Command (e.g., npx, python, node)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />
                        <TextBox Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Win11TextBox}"
                                 FontFamily="Consolas"
                                 Height="40"
                                 Margin="0,0,0,16" />

                        <!-- Arguments -->
                        <TextBlock Text="Arguments (JSON array)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />
                        <TextBox Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Win11TextBox}"
                                 FontFamily="Consolas"
                                 AcceptsReturn="True"
                                 MinHeight="60"
                                 MaxHeight="100"
                                 TextWrapping="Wrap"
                                 Margin="0,0,0,16" />

                        <!-- Working Directory -->
                        <TextBlock Text="Working Directory (optional)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />
                        <TextBox Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Win11TextBox}"
                                 Height="40"
                                 Margin="0,0,0,16" />

                        <!-- Environment Variables -->
                        <TextBlock Text="Environment Variables (JSON object)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />
                        <TextBox Text="{Binding EnvironmentVariables, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Win11TextBox}"
                                 FontFamily="Consolas"
                                 AcceptsReturn="True"
                                 MinHeight="60"
                                 MaxHeight="100"
                                 TextWrapping="Wrap"
                                 Margin="0,0,0,16" />

                        <!-- Toggles -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Enabled" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                            <ToggleButton Grid.Column="1" IsChecked="{Binding IsEnabled}" Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                        </Grid>

                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Auto-start on app launch" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                            <ToggleButton Grid.Column="1" IsChecked="{Binding AutoStart}" Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                        </Grid>

                        <!-- Buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource Win11SecondaryButton}"
                                    Command="{Binding DataContext.CancelEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Height="40"
                                    Padding="24,0"
                                    Margin="0,0,12,0">
                                <TextBlock Text="Cancel" />
                            </Button>
                            <Button Style="{StaticResource Win11PrimaryButton}"
                                    Command="{Binding DataContext.SaveServerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Height="40"
                                    Padding="24,0">
                                <TextBlock Text="Save" />
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Border>
    </Grid>
</UserControl>
